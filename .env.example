# ─────────────────────────────────────────────────────────────────────────────
# Brote — environment variables (BUILD_SPEC §17)
# Copy this file to `.env.local` and fill in the values from your dashboards.
# NEVER commit `.env.local`. The service role + VAPID private keys are secret.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server/edge only — never exposed to the client

# Google Gemini — used ONLY inside Supabase Edge Functions (free tier)
GEMINI_API_KEY=                     # https://aistudio.google.com/app/apikey

# Web Push (VAPID) — generate with `npm run vapid`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # public key (safe in client)
VAPID_PRIVATE_KEY=                  # private key (edge only)
VAPID_SUBJECT=mailto:owner@example.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000   # your https://<project>.vercel.app in prod
NEXT_PUBLIC_APP_TZ=America/Argentina/Buenos_Aires
